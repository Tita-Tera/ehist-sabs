{
  "info": {
    "name": "ehist-sabs API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000/api.php" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"name\": \"Test User\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Me (current user)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Services",
      "item": [
        {
          "name": "List providers",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/services/providers"
          }
        },
        {
          "name": "Services by provider (id=2)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/services/2"
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "List my bookings",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/bookings"
          }
        },
        {
          "name": "Create booking",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider_id\": 2,\n  \"service_id\": 1,\n  \"slot_date\": \"2026-03-15\",\n  \"start_time\": \"09:00:00\",\n  \"end_time\": \"09:30:00\"\n}"
            },
            "url": "{{baseUrl}}/bookings"
          }
        },
        {
          "name": "Cancel booking (id=1)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/bookings/1/cancel"
          }
        },
        {
          "name": "Approve booking (admin, id=1)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"approved\"\n}"
            },
            "url": "{{baseUrl}}/bookings/1/status"
          }
        }
      ]
    },
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    }
  ]
}
